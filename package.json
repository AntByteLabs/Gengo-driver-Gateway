{
  "name": "@gengo/driver-gateway",
  "version": "1.0.0",
  "description": "Real-time Socket.io v4 bidirectional communication service for Gen-Go drivers and riders",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "kafkajs": "^2.2.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "socket.io": "^4.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
