NODE_ENV=development
PORT=3011

# JWT
JWT_SECRET=your-super-secret-key-change-me-in-production

# Redis — data operations (GEOADD, HSET, GET, SET, …)
REDIS_URL=redis://localhost:6379

# Redis — pubsub subscriber connection (separate from data client)
REDIS_PUBSUB_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CONSUMER_GROUP=driver-gateway-consumer
KAFKA_TOPIC_TRIP_EVENTS=trip.events
KAFKA_TOPIC_DRIVER_LOCATION=driver.location.updated
KAFKA_TOPIC_NOTIFICATION_OUTBOX=notification.outbox

# CORS — comma-separated list of allowed origins, or * for all
CORS_ORIGINS=*
